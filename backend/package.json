{
  "name": "notes-app-backend",
  "version": "1.0.0",
  "description": "Notes App Backend API - Node.js/Express",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "mocha --require ts-node/register --extensions ts 'tests/**/*.test.ts'",
    "test:watch": "mocha --require ts-node/register --extensions ts --watch 'tests/**/*.test.ts'",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "sonarqube": "sonar-scanner"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.2",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/mocha": "^10.0.6",
    "@types/chai": "^4.3.11",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.5.3",
    "ts-node": "^10.9.2",
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "ts-mocha": "^10.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0"
  }
}
